<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:latin="http://schemas.android.com/apk/res-auto"
>
    <!-- U+0430: "а" CYRILLIC SMALL LETTER A -->
    <Key latin:keySpec="а" latin:moreKeys="!text/morekeys_cyrillic_a" />
    <!-- U+0431: "б" CYRILLIC SMALL LETTER BE -->
    <Key latin:keySpec="б" />
    <!-- U+0432: "в" CYRILLIC SMALL LETTER VE -->
    <Key latin:keySpec="в" />
    <!-- U+0433: "г" CYRILLIC SMALL LETTER GHE -->
    <Key latin:keySpec="г" latin:moreKeys="!text/morekeys_cyrillic_ghe" />
    <!-- U+0434: "д" CYRILLIC SMALL LETTER DE -->
    <Key latin:keySpec="д" />
    <!-- U+0435: "е" CYRILLIC SMALL LETTER IE -->
    <Key latin:keySpec="е" latin:moreKeys="!text/morekeys_cyrillic_ie" />
    <!-- U+0454: "є" CYRILLIC SMALL LETTER UKRAINIAN IE -->
    <Key latin:keySpec="є" />
    <!-- U+0436: "ж" CYRILLIC SMALL LETTER ZHE -->
    <Key latin:keySpec="ж" />
    <!-- U+0437: "з" CYRILLIC SMALL LETTER ZE -->
    <Key latin:keySpec="з" />
    <!-- U+0438: "и" CYRILLIC SMALL LETTER I -->
    <Key latin:keySpec="и" />
    <!-- U+0456: "і" CYRILLIC SMALL LETTER BYELORUSSIAN-UKRAINIAN I
         U+0457: "ї" CYRILLIC SMALL LETTER YI -->
    <Key latin:keySpec="і" latin:moreKeys="ї"/>
</merge>
