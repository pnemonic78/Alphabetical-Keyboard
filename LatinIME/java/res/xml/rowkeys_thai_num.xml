<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:keyboardLayoutSetElement="alphabetManualShifted|alphabetShiftLocked|alphabetShiftLockShifted">
            <!-- U+0E51: "๑" THAI DIGIT ONE -->
            <Key latin:keySpec="๑"/>
            <!-- U+0E52: "๒" THAI DIGIT TWO -->
            <Key latin:keySpec="๒"/>
            <!-- U+0E53: "๓" THAI DIGIT THREE -->
            <Key latin:keySpec="๓"/>
            <!-- U+0E54: "๔" THAI DIGIT FOUR -->
            <Key latin:keySpec="๔"/>
            <!-- U+0E55: "๕" THAI DIGIT FIVE -->
            <Key latin:keySpec="๕"/>
            <!-- U+0E56: "๖" THAI DIGIT SIX -->
            <Key latin:keySpec="๖"/>
            <!-- U+0E57: "๗" THAI DIGIT SEVEN -->
            <Key latin:keySpec="๗"/>
            <!-- U+0E58: "๘" THAI DIGIT EIGHT -->
            <Key latin:keySpec="๘"/>
            <!-- U+0E59: "๙" THAI DIGIT NINE -->
            <Key latin:keySpec="๙"/>
            <!-- U+0E50: "๐" THAI DIGIT ZERO -->
            <Key latin:keySpec="๐"/>
        </case>
        <default>
            <!-- U+0E51: "๑" THAI DIGIT ONE -->
            <Key
                latin:additionalMoreKeys="1,๑"
                latin:keySpec="1" />
            <!--U+0E52: "๒" THAI DIGIT TWO -->
            <Key
                latin:additionalMoreKeys="2,๒"
                latin:keySpec="2" />
            <!-- U+0E53: "๓" THAI DIGIT THREE -->
            <Key
                latin:additionalMoreKeys="3,๓"
                latin:keySpec="3" />
            <!-- U+0E54: "๔" THAI DIGIT FOUR -->
            <Key
                latin:additionalMoreKeys="4,๔"
                latin:keySpec="4" />
            <!-- U+0E55: "๕" THAI DIGIT FIVE -->
            <Key
                latin:additionalMoreKeys="5,๕"
                latin:keySpec="5" />
            <!-- U+0E56: "๖" THAI DIGIT SIX -->
            <Key
                latin:additionalMoreKeys="6,๖"
                latin:keySpec="6" />
            <!-- U+0E57: "๗" THAI DIGIT SEVEN -->
            <Key
                latin:additionalMoreKeys="7,๗"
                latin:keySpec="7" />
            <!-- U+0E58: "๘" THAI DIGIT EIGHT -->
            <Key
                latin:additionalMoreKeys="8,๘"
                latin:keySpec="8" />
            <!-- U+0E59: "๙" THAI DIGIT NINE -->
            <Key
                latin:additionalMoreKeys="9,๙"
                latin:keySpec="9" />
            <!-- U+0E50: "๐" THAI DIGIT ZERO -->
            <Key
                latin:additionalMoreKeys="0,๐"
                latin:keySpec="0" />
        </default>
    </switch>
</merge>
